# Dashboard configuration
PORT=3000

# Solana network endpoints
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com
SOLANA_WS_URL=wss://api.mainnet-beta.solana.com

# Yellowstone gRPC settings (Leave blank for standard WebSocket fallbacks)
YELLOWSTONE_GRPC_URL=
YELLOWSTONE_GRPC_TOKEN=

# Jito Block Engine configuration
JITO_BLOCK_ENGINE_URL=https://mainnet.block-engine.jito.wtf

# Private key for Jito bundle payer (base58 format)
# If left blank, a random mock keypair is generated for safety and testing
SENDER_PRIVATE_KEY=

# AI Agent configuration ('mock' | 'openai' | 'anthropic')
AI_PROVIDER=mock
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Simulation harness (Set to true to run mock lifecycles for demo testing)
SIMULATE_TRANSACTIONS=true
